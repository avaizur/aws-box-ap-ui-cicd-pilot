pipeline {
    agent any

    environment {
        AWS_CREDS_ID = 'aws-pilot-credentials'
        AWS_REGION = 'eu-west-2'
        PROJECT_NAME = 'aws-box-ap-val'
        DB_PASSWORD = credentials('rds-db-password')
    }

    stages {
        stage('Approval: Clean Orphaned Resources') {
            steps {
                script {
                    input message: "Do you want to run the automated cleanup script to remove orphaned AWS resources from previous failed runs?", ok: "Clean Up"
                }
            }
        }

        stage('Cleanup Orphaned Resources') {
            steps {
                script {
                    withCredentials([usernamePassword(
                        credentialsId: "${AWS_CREDS_ID}",
                        usernameVariable: 'AWS_ACCESS_KEY_ID',
                        passwordVariable: 'AWS_SECRET_ACCESS_KEY')]) {
                        withEnv(["AWS_DEFAULT_REGION=${AWS_REGION}"]) {
                            sh "chmod +x scripts/orphan_cleanup.sh"
                            sh "./scripts/orphan_cleanup.sh"
                        }
                    }
                }
            }
        }

        stage('Terraform Plan (Base Infrastructure)') {
            steps {
                dir('infrastructure') {
                    script {
                        withCredentials([usernamePassword(
                            credentialsId: "${AWS_CREDS_ID}",
                            usernameVariable: 'AWS_ACCESS_KEY_ID',
                            passwordVariable: 'AWS_SECRET_ACCESS_KEY')]) {
                            withEnv(["AWS_DEFAULT_REGION=${AWS_REGION}"]) {
                                sh 'terraform init'
                                sh "terraform plan -out=tfplan_base -var='db_password=${DB_PASSWORD}' -var='project_name=${PROJECT_NAME}' -var='aws_region=${AWS_REGION}' -var='deploy_app_runner=false'"
                            }
                        }
                    }
                }
            }
        }

        stage('Approval: Provision Infrastructure') {
            steps {
                script {
                    input message: "Review the Terraform plan. Do you want to apply these changes?", ok: "Apply"
                }
            }
        }

        stage('Terraform Apply (Base Infrastructure)') {
            steps {
                dir('infrastructure') {
                    script {
                        withCredentials([usernamePassword(
                            credentialsId: "${AWS_CREDS_ID}",
                            usernameVariable: 'AWS_ACCESS_KEY_ID',
                            passwordVariable: 'AWS_SECRET_ACCESS_KEY')]) {
                            withEnv(["AWS_DEFAULT_REGION=${AWS_REGION}"]) {
                                sh 'terraform apply -auto-approve tfplan_base'

                                // Capture ECR URL for Backend build
                                env.ECR_URL = sh(script: "terraform output -raw ecr_repository_url", returnStdout: true).trim()
                            }
                        }
                    }
                }
            }
        }

        stage('Backend Build & Push') {
            steps {
                dir('backend-pilot') {
                    script {
                        withCredentials([usernamePassword(
                            credentialsId: "${AWS_CREDS_ID}",
                            usernameVariable: 'AWS_ACCESS_KEY_ID',
                            passwordVariable: 'AWS_SECRET_ACCESS_KEY')]) {
                            withEnv(["AWS_DEFAULT_REGION=${AWS_REGION}"]) {
                                // 1. Docker Login
                                sh "aws ecr get-login-password --region ${AWS_REGION} | docker login --username AWS --password-stdin ${env.ECR_URL}"

                                // 2. Build & Push
                                sh "docker build -t ${env.ECR_URL}:latest ."
                                sh "docker push ${env.ECR_URL}:latest"
                            }
                        }
                    }
                }
            }
        }

        stage('Terraform Apply (App Runner)') {
            steps {
                dir('infrastructure') {
                    script {
                        withCredentials([usernamePassword(
                            credentialsId: "${AWS_CREDS_ID}",
                            usernameVariable: 'AWS_ACCESS_KEY_ID',
                            passwordVariable: 'AWS_SECRET_ACCESS_KEY')]) {
                            withEnv(["AWS_DEFAULT_REGION=${AWS_REGION}"]) {
                                // Now that the image exists, plan and apply the rest of the infrastructure
                                sh "terraform plan -out=tfplan_apprunner -var='db_password=${DB_PASSWORD}' -var='project_name=${PROJECT_NAME}' -var='aws_region=${AWS_REGION}' -var='deploy_app_runner=true'"
                                sh "terraform apply -auto-approve tfplan_apprunner"

                                // Capture App Runner URL for Frontend build
                                env.API_URL = sh(script: "terraform output -raw service_url", returnStdout: true).trim()
                            }
                        }
                    }
                }
            }
        }

        stage('Frontend Build & Deploy') {
            steps {
                dir('.') {
                    sh "echo 'VITE_API_URL=https://${env.API_URL}/api' > .env.production"
                    sh 'npm install'
                    sh 'npm run build'

                    withCredentials([usernamePassword(
                        credentialsId: "${AWS_CREDS_ID}",
                        usernameVariable: 'AWS_ACCESS_KEY_ID',
                        passwordVariable: 'AWS_SECRET_ACCESS_KEY')]) {
                        withEnv(["AWS_DEFAULT_REGION=${AWS_REGION}"]) {
                            // Assuming S3 bucket name is known or passed as env
                            sh "aws s3 sync dist/ s3://${PROJECT_NAME}-frontend/pilot-validation/ --delete"
                        }
                    }
                }
            }
        }

        stage('Smoke Validation') {
            steps {
                script {
                    echo "Running Extended Smoke Validation..."

                    // 1. Validate Backend Startup & OpenAPI Docs
                    echo "Checking API Health at: https://${env.API_URL}/api/v3/api-docs"
                    def response = sh(script: "curl -s -o /dev/null -w '%{http_code}' https://${env.API_URL}/api/v3/api-docs", returnStdout: true).trim()

                    if (response == "200") {
                        echo "SUCCESS: Backend is UP and responding to API requests."
                    } else {
                        error "FAILURE: Backend responded with HTTP ${response}"
                    }

                    // 2. Validate DB Connectivity
                    echo "Checking application health/DB connection..."
                    // Assuming /api/health or /api/actuator/health is exposed
                    def healthResponse = sh(script: "curl -s -o /dev/null -w '%{http_code}' https://${env.API_URL}/api/actuator/health", returnStdout: true).trim()
                    if (healthResponse == "200") {
                        echo "SUCCESS: Application health (and DB connection) is UP."
                    } else {
                        echo "WARNING: /api/actuator/health returned ${healthResponse}. Check if actuator is enabled and DB is connected."
                    }

                    echo "Smoke validation passed successfully!"
                }
            }
        }

        stage('Approval: Destroy Infrastructure') {
            steps {
                script {
                    input message: "Validation complete. Do you want to destroy the temporary infrastructure?", ok: "Destroy"
                }
            }
        }

        stage('Terraform Destroy') {
            steps {
                dir('infrastructure') {
                    script {
                        withCredentials([usernamePassword(
                            credentialsId: "${AWS_CREDS_ID}",
                            usernameVariable: 'AWS_ACCESS_KEY_ID',
                            passwordVariable: 'AWS_SECRET_ACCESS_KEY')]) {
                            withEnv(["AWS_DEFAULT_REGION=${AWS_REGION}"]) {
                                sh "terraform destroy -auto-approve -var='db_password=${DB_PASSWORD}' -var='project_name=${PROJECT_NAME}' -var='aws_region=${AWS_REGION}' -var='deploy_app_runner=true'"
                            }
                        }
                    }
                }
            }
        }
    }

    post {
        always {
            cleanWs()
        }
    }
}
